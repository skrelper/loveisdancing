---
import '../assets/home.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="description" content="Home">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta property="og:title" content="Max Bass">
    <meta property="og:description" content="Home">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://loveisdancing.com/content/images/everything.png">
    <meta property="og:url" content="https://loveisdancing.com/home">
    <title>Max Bass - Home</title>

    <link rel="icon" type="image/svg+xml" href="/content/svg/favicon2.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Doto:wght@100..900&family=Inter+Tight:ital,wght@0,100..900;1,100..900&family=Jacquard+12+Charted&family=Jersey+10&family=Micro+5+Charted&family=Pixelify+Sans:wght@400..700&family=Rubik+Broken+Fax&family=Silkscreen:wght@400;700&family=Syne+Mono&display=swap" rel="stylesheet">

  <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "wv5ok28jme");
    </script>

</head>

<body>

  <audio id="hover-audio" src="/content/audio/fx/dance_chords.ogg"></audio>
  <audio id="hover-audio2" src="/content/audio/fx/lid-intro-cut.ogg"></audio>
  <div class="container1">
    <div class="center-wrap">
      <div class="main-icons">
        <div class="icon">
        <a href="/files"><img src="/content/svg/Files_p.svg" id="files"><h4 class="filename">File Explorer</h4></a>
        </div>

        <div class="icon">
          <a href="/heartbeat"><img src="/content/svg/Music_p.svg" id="music"><h4 class="filename">Music</h4></a>
        </div>

        <!-- <div class="icon">
          <a href="https://www.instagram.com/maxsdemos/" target="_blank"><img src="/content/svg/Contact_p.svg" id="contact"></a>
        </div> -->
      </div>
    </div>

    <p id="sitemap"><a href="/sitemap">Sitemap</a></p>
  </div>

<script src="/scripts/spinner.js" is:inline></script>

  <script src="/scripts/fix-vh.js" is:inline></script>
  <script>
    // @ts-nocheck
  const images = document.querySelectorAll("img");
  const audio = document.getElementById("hover-audio")!;
  const audiocut = document.getElementById("hover-audio2")!;
  const text = document.querySelectorAll("p");

audio.addEventListener("ended", () => {
  audio.currentTime = 0;
  audio.play();
});

audiocut.addEventListener("ended", () => {
  audiocut.currentTime = 0;
  audiocut.play();
});

  images.forEach(img => {
    img.addEventListener("mouseover", () => audio.play());
    img.addEventListener("mouseleave", () => audio.pause());
  });

  text.forEach(p => {
    p.addEventListener("mouseover", () => audiocut.play());
    p.addEventListener("mouseleave", () => audiocut.pause());
  })

  document.body.addEventListener("click", () => {
  audio.play().then(() => audio.pause());
}, { once: true });

</script>
</body>
</html>